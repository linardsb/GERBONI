# TEMPLATE FILE - DO NOT COMMIT WITH REAL VALUES
# Copy this file to secrets.yaml and fill in real values
# Then apply with: kubectl apply -f secrets.yaml
#
# To create base64 encoded values:
#   echo -n 'your-secret-value' | base64
#
# Or use kubectl to create the secret directly:
#   kubectl create secret generic gerboni-secrets \
#     --namespace=gerboni \
#     --from-literal=DATABASE_URL='postgresql+asyncpg://...' \
#     --from-literal=SECRET_KEY='your-jwt-secret' \
#     --from-literal=STRIPE_SECRET_KEY='sk_live_...' \
#     --from-literal=STRIPE_WEBHOOK_SECRET='whsec_...' \
#     --from-literal=ANTHROPIC_API_KEY='sk-ant-...'

apiVersion: v1
kind: Secret
metadata:
  name: gerboni-secrets
  namespace: gerboni
  labels:
    app.kubernetes.io/name: gerboni-secrets
    app.kubernetes.io/part-of: gerboni-platform
type: Opaque
data:
  # Database connection string (base64 encoded)
  # postgresql+asyncpg://user:password@host:5432/gerboni
  DATABASE_URL: <BASE64_ENCODED_DATABASE_URL>

  # JWT secret key (base64 encoded)
  # Generate with: openssl rand -hex 32
  SECRET_KEY: <BASE64_ENCODED_SECRET_KEY>

  # Stripe API keys (base64 encoded)
  STRIPE_SECRET_KEY: <BASE64_ENCODED_STRIPE_SECRET_KEY>
  STRIPE_PUBLISHABLE_KEY: <BASE64_ENCODED_STRIPE_PUBLISHABLE_KEY>
  STRIPE_WEBHOOK_SECRET: <BASE64_ENCODED_STRIPE_WEBHOOK_SECRET>

  # Anthropic API key for AI agent (base64 encoded)
  ANTHROPIC_API_KEY: <BASE64_ENCODED_ANTHROPIC_API_KEY>
